---
import './About.css';
interface Props {
  t: any;
}
const { t } = Astro.props;
---

<section class="about section-padding" id="about">
  <div class="container">
    <div class="about-grid">
      <div class="about-text-content">
        <h2 class="section-title text-left">{t.about.title}</h2>
        <p class="about-description">{t.about.p1}</p>
        <p class="about-description">{t.about.p2}</p>
        
        <div class="stats-row">
          {t.about.stats.map((stat: any, idx: number) => (
            <div class="stat-item glass">
              <span class="stat-number">{stat.num}</span>
              <span class="stat-label">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>
      
      <div class="about-visual">
        <div class="visual-card glass">
          <div class="visual-graphic">
            <div class="circle circle-1"></div>
            <div class="circle circle-2"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
