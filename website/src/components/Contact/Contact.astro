---
import './Contact.css';
interface Props {
  t: any;
}
const { t } = Astro.props;
---

<section class="contact section-padding" id="contact">
  <div class="container">
    <div class="contact-wrapper glass">
      <div class="contact-info">
        <h2 class="contact-title">{t.contact.title}</h2>
        <p class="contact-desc">{t.contact.desc}</p>
        
        <div class="contact-methods">
          <div class="method">
            <span class="method-label">{t.contact.email}</span>
            <a href="mailto:eagustyack+work@gmail.com" class="method-value">eagustyack+work@gmail.com</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
