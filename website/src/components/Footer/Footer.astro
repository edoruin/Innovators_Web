---
import './Footer.css';
interface Props {
  t: any;
}
const { t } = Astro.props;
const base = import.meta.env.BASE_URL;
const currentYear = new Date().getFullYear();
---

<footer class="footer" id="payment">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <h3 class="footer-logo">Innovation Group</h3>
        <p class="footer-desc">{t.footer.desc}</p>
      </div>
      
      <div class="footer-links">
        <h4 class="footer-title">{t.footer.navTitle}</h4>
        <a href="#home">{t.footer.nav[0]}</a>
        <a href="#about">{t.footer.nav[1]}</a>
        <a href="#services">{t.footer.nav[2]}</a>
        <a href="#team">{t.footer.nav[3]}</a>
      </div>
      
      <div class="footer-contact">
        <h4 class="footer-title">{t.footer.contactTitle}</h4>
        <p class="footer-text">eagustyack+work@gmail.com</p>
      </div>

      <div class="footer-paid-methods">
        <h4 class="footer-title">{t.footer.paidMethodsTitle}</h4>
        <div class="paid-methods-logos">
          <a href="https://paypal.me/innovationgroup" target="_blank" rel="noopener" class="paypal-link">
            <img src={base + "paypal-logo.svg"} alt="PayPal" class="paypal-logo" />
          </a>
          <a href="https://pay.binance.com" target="_blank" rel="noopener" class="paypal-link">
            <img src={base + "binance.png"} alt="Binance" class="paypal-logo" />
          </a>
        </div>
      </div>
    </div>
    
    <div class="footer-bottom">
      <p>&copy; {currentYear} Innovation Group. {t.footer.rights}</p>
    </div>
  </div>
</footer>
