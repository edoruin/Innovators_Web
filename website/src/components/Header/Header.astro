---
import './Header.css';
interface Props {
  t: any;
  lang: string;
}
const { t, lang } = Astro.props;
const base = import.meta.env.BASE_URL;
const togglePath = lang === 'es' ? base + 'en' : base;
---

<header class="header" id="main-header">
  <div class="container header-container">
    <a href="#home" class="logo">
      <img src={base + "logo.png"} alt="Innovation Group Logo" />
    </a>
    <nav class="nav-menu">
      <a href="#about" class="nav-link">{t.nav.about}</a>
      <a href="#services" class="nav-link">{t.nav.services}</a>
      <a href="#team" class="nav-link">{t.nav.team}</a>
      <a href="#payment" class="nav-link">{t.nav.payment}</a>
    </nav>
    <div class="nav-cta-wrapper" style="display: flex; gap: 1rem; align-items: center;">
      <a href={togglePath} class="lang-toggle-btn" style="background: transparent; border: 1px solid var(--text-secondary); padding: 0.4rem 0.8rem; border-radius: 4px; cursor: pointer; font-weight: bold; color: inherit; text-decoration: none;">
        {lang === 'es' ? 'EN' : 'ES'}
      </a>
      <a href="#contact" class="cta-button nav-cta">{t.nav.contact}</a>
    </div>
  </div>
</header>

<script>
  // Client-side scroll detection for header glassmorphism
  const header = document.getElementById('main-header');
  window.addEventListener('scroll', () => {
    if (header) {
      if (window.scrollY > 50) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
    }
  });
</script>
