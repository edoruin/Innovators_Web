---
import './Hero.css';
interface Props {
  t: any;
}
const { t } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section class="hero" id="home">
  <div class="container hero-container fade-in">
    <div class="hero-content">
      <h1 class="hero-title">{t.hero.title}</h1>
      <p class="hero-subtitle">{t.hero.subtitle}</p>
      
      <div class="hero-actions">
        <a href="#services" class="btn btn-primary">{t.hero.btn1}</a>
        <a href="#contact" class="btn btn-outline">{t.hero.btn2}</a>
      </div>
    </div>
    
    <div class="hero-visual">
      <div class="mockup-container">
        <div class="phone-mockup">
          <div class="phone-screen">
            <div class="app-header">
              <span class="app-logo">CAJUCEL</span>
            </div>
            <div class="app-chart">
              <div class="bar" style="height: 30%"></div>
              <div class="bar" style="height: 50%"></div>
              <div class="bar" style="height: 20%"></div>
              <div class="bar" style="height: 80%"></div>
              <div class="bar" style="height: 60%"></div>
              <div class="bar" style="height: 90%"></div>
              <div class="bar" style="height: 40%"></div>
            </div>
            <div class="app-content">
              <div class="app-line"></div>
              <div class="app-line short"></div>
            </div>
          </div>
        </div>
        <div class="background-decoration">
          <img src={base + "Innovators.png"} alt="Innovators" />
        </div>
      </div>
    </div>
  </div>
</section>
