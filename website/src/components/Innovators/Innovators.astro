---
import './Innovators.css';
interface Props {
  t: any;
}
const { t } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section class="innovators section-padding" id="team">
  <div class="container">
    <h2 class="section-title">{t.innovators.title}</h2>
    <p class="innovators-subtitle">{t.innovators.subtitle}</p>
    
    <div class="innovators-grid">
      <div class="innovator-card glass">
        <div class="avatar-container">
          <img src={base + "edwinporfoliologo.png"} alt="Edwin Agustín" class="innovator-avatar" />
        </div>
        <div class="innovator-info">
          <h3 class="innovator-name">Edwin Agustín</h3>
          <span class="founder-badge">Jefe de Sistemas Embebidos</span>
          <p class="innovator-role">Estudiante en Ciencias de Datos</p>
          <p class="innovator-desc">{t.innovators.desc}</p>
          
          <div class="innovator-links">
            <a href="https://edoruin.github.io/Myself/" target="_blank" rel="noopener" class="inv-link">{t.innovators.links[0]}</a>
            <a href="https://www.linkedin.com/in/edwin-jeremias-agustin" target="_blank" rel="noopener" class="inv-link linkedin">{t.innovators.links[1]}</a>
          </div>
        </div>
      </div>

      <div class="innovator-card glass sheily-card">
        <div class="avatar-container">
          <img src={base + "SHeilyporfolioLogo.jpg"} alt="SHeily Marie Perez" class="innovator-avatar" />
        </div>
        <div class="innovator-info">
          <h3 class="innovator-name">SHeily Marie Perez</h3>
          <span class="founder-badge">Jefa de Apoyo Académico</span>
          <p class="innovator-role">Bióloga Marina</p>
          <p class="innovator-desc">Bióloga y M.Sc. en Ciencias Marinas. AI & Tech for Conservation. Mentora STEM</p>
          <div class="innovator-links">
            <a href="https://www.linkedin.com/in/perez-herrera-b06781268/?locale=es" target="_blank" rel="noopener" class="inv-link linkedin">LinkedIn</a>
          </div>
        </div>
      </div>

      <div class="innovator-card glass">
        <div class="avatar-container">
          <img src={base + "isaacporfoliologo.png"} alt="Isaac Rosario" class="innovator-avatar" />
        </div>
        <div class="innovator-info">
          <h3 class="innovator-name">Isaac Rosario</h3>
          <span class="founder-badge">Jefe de Desarrollo en IA y Software</span>
          <p class="innovator-role">Estudiante en Inteligencia Artificial</p>
          <p class="innovator-desc">Estudiante en Inteligencia Artificial, apasionado por la administración y creación de servidores Linux, desarrollo de software y soluciones de IA escalables.</p>
          <div class="innovator-links">
            <a href="https://www.linkedin.com/in/isaac-rosario-santiago-313550319/" target="_blank" rel="noopener" class="inv-link linkedin">LinkedIn</a>
          </div>
        </div>
      </div>

      <div class="innovator-card glass">
        <div class="avatar-container">
          <img src={base + "Aubreyporfoliologo.jpg"} alt="Aubrey Torres" class="innovator-avatar" />
        </div>
        <div class="innovator-info">
          <h3 class="innovator-name">Aubrey Torres</h3>
          <span class="founder-badge">Jefa de Análisis de Datos</span>
          <p class="innovator-role">Científica de Datos</p>
          <p class="innovator-desc">Científica de Datos con experiencia en análisis de datos, manejo avanzado de Excel, estadística y RStudio para la transformación de información en decisiones estratégicas.</p>
          <div class="innovator-links">
            <a href="https://www.linkedin.com/in/aubrey-marie-abreu-torres/" target="_blank" rel="noopener" class="inv-link linkedin">LinkedIn</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
