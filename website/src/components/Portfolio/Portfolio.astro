---
import './Portfolio.css';
interface Props {
  t: any;
}
const { t } = Astro.props;
---

<section class="portfolio section-padding" id="portfolio">
  <div class="container">
    <h2 class="section-title">{t.portfolio.title}</h2>
    
    <div class="portfolio-grid">
      {t.portfolio.list.map((proj: any) => (
        <div class="portfolio-card glass">
          <div class="portfolio-content">
            <h3 class="portfolio-name">{proj.name}</h3>
            <p class="portfolio-desc">{proj.desc}</p>
            
            <div class="portfolio-details">
              <div class="detail-group">
                <span class="detail-label">{t.portfolio.problem}</span>
                <p class="detail-text">{proj.prob}</p>
              </div>
              <div class="detail-group result">
                <span class="detail-label">{t.portfolio.impact}</span>
                <p class="detail-text highlight">{proj.res}</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
