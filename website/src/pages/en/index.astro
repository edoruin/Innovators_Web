---
// pages/en/index.astro (English)
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header/Header.astro';
import Hero from '../../components/Hero/Hero.astro';
import News from '../../components/News/News.astro';
import About from '../../components/About/About.astro';
import Services from '../../components/Services/Services.astro';
import Innovators from '../../components/Innovators/Innovators.astro';
import Payment from '../../components/Payment/Payment.astro';
import Benefits from '../../components/Benefits/Benefits.astro';
import Testimonials from '../../components/Testimonials/Testimonials.astro';
import Contact from '../../components/Contact/Contact.astro';
import Footer from '../../components/Footer/Footer.astro';

import { locales } from '../../utils/locales.js';
const lang = 'en';
const t = locales[lang];
---

<Layout title="Innovation Group | Technology & Innovation" lang={lang}>
  <Header t={t} lang={lang} />
  <main>
    <Hero t={t} />
    <News t={t} />
    <About t={t} />
    <Services t={t} />
    <Innovators t={t} />
    <Payment t={t} />
    <Benefits t={t} />
    <Testimonials t={t} />
    <Contact t={t} />
  </main>
  <Footer t={t} />
</Layout>
